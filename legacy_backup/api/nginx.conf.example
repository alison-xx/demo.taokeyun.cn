server {
    listen 80;
    server_name demo.taokeyun.cn;

    root /www/wwwroot/demo.taokeyun.cn;
    index index.html index.php;

    # 前端静态文件
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API接口
    location /api {
        alias /www/wwwroot/demo.taokeyun.cn/api/public;
        try_files $uri $uri/ /api/public/index.php?$query_string;

        location ~ \.php$ {
            fastcgi_pass unix:/tmp/php-cgi-73.sock;
            fastcgi_index index.php;
            fastcgi_param SCRIPT_FILENAME $request_filename;
            include fastcgi_params;
        }
    }

    # 禁止访问敏感文件
    location ~ /\.(env|git) {
        deny all;
        return 404;
    }

    location ~ ^/(api)/(config|app|database|storage)/ {
        deny all;
        return 404;
    }
}
